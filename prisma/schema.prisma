generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int         @id @unique @default(autoincrement())
  email         String      @unique
  name          String?
  password      String
  role          USER_ROLE   @default(user)
  profile_image String?     @default("https://i.ibb.co/z5YHLV9/profile.png")
  status        USER_STATUS @default(active)
  verified      Boolean     @default(false)
  package_id    Int?
  onetime_code  String?
  expires_at    DateTime?
  package       Package?    @relation(fields: [package_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  folders    Folder[]
  files      File[]
}

model Package {
  id                    Int      @id @default(autoincrement())
  name                  String
  total_max_folder      Int
  max_nesting_folder    Int
  allowed_file_type     String[]
  max_file_size         Int
  total_file_limit      Int
  file_per_folder_limit Int
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  users                 User[]
}

model Folder {
  id               Int    @id @default(autoincrement())
  name             String
  user_id          Int
  parent_folder_id Int?
  user             User   @relation(fields: [user_id], references: [id])

  parent  Folder?  @relation("FolderToFolders", fields: [parent_folder_id], references: [id])
  folders Folder[] @relation("FolderToFolders")

  nesting_level Int    @default(0)
  total_files   Int    @default(0)
  files         File[]
}

model File {
  id        Int     @id @default(autoincrement())
  folder_id Int?
  folder    Folder? @relation(fields: [folder_id], references: [id])
  name      String
  user_id   Int
  user      User   @relation(fields: [user_id], references: [id])
  path_name String
  file_type String
  size      Int
}

enum USER_ROLE {
  super_admin
  admin
  user
}

enum USER_STATUS {
  active
  block
}
